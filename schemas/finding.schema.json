{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "finding",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "module": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "corpus-limit",
        "structural",
        "semantic",
        "epistemic",
        "scene",
        "paragraph",
        "sentence",
        "language",
        "style",
        "copy"
      ]
    },
    "category": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "mechanism": {
      "type": "string"
    },
    "evidence_spans": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "start_anchor": {
            "type": "string"
          },
          "end_anchor": {
            "type": "string"
          },
          "quote": {
            "type": "string"
          }
        },
        "required": [
          "start_anchor"
        ]
      }
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "revision_implication": {
      "type": "string"
    },
    "false_positive_risk": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "module",
    "level",
    "category",
    "description",
    "severity",
    "confidence",
    "false_positive_risk"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "severity": {
            "enum": [
              "high",
              "critical"
            ]
          }
        }
      },
      "then": {
        "required": [
          "mechanism",
          "evidence_spans",
          "revision_implication"
        ]
      }
    }
  ]
}
