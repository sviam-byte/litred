{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "segment_map",
  "type": "object",
  "properties": {
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "start_anchor": {
            "type": "string"
          },
          "end_anchor": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "scene",
              "summary",
              "exposition",
              "argument",
              "reflection",
              "dialogue",
              "description",
              "mixed",
              "uncertain"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "mode",
          "confidence"
        ]
      }
    },
    "transition_alerts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "segments"
  ]
}